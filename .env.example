# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin password (protects /library/admin and the cataloging tool)
ADMIN_PASSWORD=choose-a-strong-password

# Passphrase visitors must enter to complete a booking
NEXT_PUBLIC_BORROW_PASSPHRASE=your-passphrase

# Resend (email)
RESEND_API_KEY=re_...

# Anthropic API — optional, used for AI book identification in the catalog tool
ANTHROPIC_API_KEY=sk-ant-...

# Cron secret — used to authenticate Vercel cron calls for reminder emails
CRON_SECRET=choose-a-random-string
